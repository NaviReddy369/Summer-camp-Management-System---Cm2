# ---------------------------------------------------------------
# CM2 Summer Camp — Environment Variables
# ---------------------------------------------------------------
# Copy this file to .env (local) or set these in Vercel → Settings
# → Environment Variables for production deployments.
# ---------------------------------------------------------------

# === DATABASE ===
# Set in production only — local dev falls back to SQLite (camp.db).
# Auto-populated by Vercel when you attach a Neon / Postgres database.
POSTGRES_URL=

# === EMAIL (Resend) ===
# Get an API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxx

# The "From" address. Must be from a verified domain on Resend.
# For testing you can use: "CM2 Camp <onboarding@resend.dev>"
RESEND_FROM_EMAIL="CM2 Camp <onboarding@resend.dev>"

# === FRONTEND URL ===
# Used in emails so links point to the right place.
# Production: https://your-app.vercel.app
# Local dev:  http://localhost:5173
FRONTEND_URL=http://localhost:5173
